# Airtable configuration for the contact form.
# Copy to .env for local development, and set these in Railway → Variables for production.

# Airtable Personal Access Token with data.records:write scope for the target base.
AIRTABLE_TOKEN=patXXXXXXXXXXXXXX.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Base ID (starts with "app…") — visible in the Airtable API docs URL for your base.
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# Table name or Table ID where inquiries are written (e.g. "Inquiries" or "tblXXXXXXXXXX").
AIRTABLE_TABLE=Inquiries

# Optional: notify email shown in the UI (falls back to admin@equityguardians.com).
PUBLIC_CONTACT_EMAIL=admin@equityguardians.com

# ─── Partner Realtor portal ─────────────────────────────────────────────────
# Shared passcode for /partners access. Rotate any time; existing sessions
# stay valid until they naturally expire (~8h).
PARTNER_PASSCODE=CHANGE-ME-BEFORE-PROD

# Random 32+ character secret used to sign the partner session cookie.
# If unset, a per-process fallback is generated at boot (fine, but every
# redeploy signs everyone out). Recommended for production.
PARTNER_SESSION_SECRET=CHANGE-ME-TO-A-LONG-RANDOM-STRING

# Airtable table for partner-submitted Texas member intake forms.
# Falls back to AIRTABLE_TABLE_INTAKE_TX if this is unset.
AIRTABLE_TABLE_INTAKE_TX=Texas Intake

# Airtable table for Partner Realtor Enrollment submissions (company-wide).
# Duplicates are versioned in-place: prior records are marked Superseded and
# the newest is marked Current. Never delete-replace.
AIRTABLE_TABLE_PARTNER_ENROLL=Partner Enrollments
