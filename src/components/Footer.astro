---
import { site, nav } from '../data/site';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <div class="brand">
          <img src="/logo.jpg" alt="" width="52" height="52" />
          <div>
            <div class="brand-name">Equity Guardians</div>
            <div class="brand-motto">Save · Earn · Protect</div>
          </div>
        </div>
        <p class="footer-tagline">
          Empowering homeowners to protect and utilize their home equity: the single most valuable
          asset most Americans will ever own.
        </p>
      </div>

      <div class="footer-col">
        <h4>Company</h4>
        <ul>
          {nav.map((n) => <li><a href={n.href}>{n.label}</a></li>)}
        </ul>
      </div>

      <div class="footer-col">
        <h4>Services</h4>
        <ul>
          <li><a href="/services#foreclosure-protection">Foreclosure Protection</a></li>
          <li><a href="/services#curated-savings">Curated Savings</a></li>
          <li><a href="/services#foreclosure-recovery">Foreclosure Recovery</a></li>
          <li><a href="/services#representation">Legal Representation</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Contact</h4>
        <ul class="contact-list">
          <li>
            <a href={site.contact.phoneHref}>{site.contact.phone}</a>
          </li>
          <li>
            <a href={`mailto:${site.contact.email}`}>{site.contact.email}</a>
          </li>
          <li>
            {site.contact.address.line1}<br />
            {site.contact.address.line2}
          </li>
          <li>{site.contact.hours}</li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p>© {year} Equity Guardians. All rights reserved.</p>
      <p class="disclaimer">
        Legal representation subject to attorney-client engagement. Results are not guaranteed;
        past outcomes do not predict future results. Service availability varies by state.
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--navy-950);
    color: rgba(255, 255, 255, 0.72);
    padding-block: 4rem 1.5rem;
    margin-top: 4rem;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1.2fr;
    gap: 3rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .footer-brand .brand {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    margin-bottom: 1rem;
  }
  .footer-brand img {
    width: 52px;
    height: 52px;
    border-radius: 12px;
    background: white;
    padding: 4px;
    object-fit: cover;
  }
  .brand-name {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    color: white;
    font-weight: 500;
  }
  .brand-motto {
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    color: var(--teal-400);
    text-transform: uppercase;
    margin-top: 4px;
    font-weight: 600;
  }
  .footer-tagline {
    color: rgba(255,255,255,0.62);
    font-size: 0.95rem;
    line-height: 1.65;
    max-width: 38ch;
  }

  .footer-col h4 {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--teal-400);
    font-weight: 600;
    margin-bottom: 1rem;
  }
  .footer-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .footer-col a {
    color: rgba(255,255,255,0.78);
    font-size: 0.94rem;
  }
  .footer-col a:hover { color: white; }
  .contact-list li { color: rgba(255,255,255,0.7); font-size: 0.92rem; line-height: 1.55; }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1.5rem;
    padding-top: 1.5rem;
    font-size: 0.82rem;
    color: rgba(255,255,255,0.5);
  }
  .disclaimer { max-width: 60ch; text-align: right; }

  @media (max-width: 900px) {
    .footer-grid { grid-template-columns: 1fr 1fr; gap: 2rem; }
    .footer-bottom { flex-direction: column; gap: 0.5rem; }
    .disclaimer { text-align: left; }
  }
  @media (max-width: 520px) {
    .footer-grid { grid-template-columns: 1fr; }
  }
</style>
