---
import { nav, site } from '../data/site';
const pathname = Astro.url.pathname;
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand" aria-label={`${site.name} home`}>
      <img src="/logo.jpg" alt="" width="44" height="44" class="brand-logo" />
      <span class="brand-text">
        <span class="brand-name">Equity Guardians</span>
        <span class="brand-motto">Save · Earn · Protect</span>
      </span>
    </a>

    <nav class="primary-nav" aria-label="Primary">
      <ul>
        {nav.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={['nav-link', pathname === item.href && 'is-active']}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="header-cta">
      <a href={site.contact.phoneHref} class="phone-link" aria-label={`Call ${site.contact.phone}`}>
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        <span>{site.contact.phone}</span>
      </a>
      <a href="/contact" class="btn btn-primary btn-sm">Get Protected</a>
    </div>

    <button class="menu-toggle" aria-label="Toggle menu" aria-expanded="false" aria-controls="mobile-nav">
      <span></span><span></span><span></span>
    </button>
  </div>

  <nav id="mobile-nav" class="mobile-nav" aria-label="Mobile">
    <ul>
      {nav.map((item) => (
        <li>
          <a href={item.href} class:list={['nav-link', pathname === item.href && 'is-active']}>
            {item.label}
          </a>
        </li>
      ))}
      <li><a href={site.contact.phoneHref} class="nav-link">{site.contact.phone}</a></li>
      <li><a href="/contact" class="btn btn-primary" style="width:100%; justify-content:center;">Get Protected</a></li>
    </ul>
  </nav>
</header>

<script>
  const header = document.querySelector('.site-header');
  const toggle = document.querySelector('.menu-toggle');
  const mobileNav = document.getElementById('mobile-nav');

  window.addEventListener('scroll', () => {
    header?.classList.toggle('is-scrolled', window.scrollY > 12);
  }, { passive: true });

  toggle?.addEventListener('click', () => {
    const open = mobileNav?.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', String(!!open));
    document.body.style.overflow = open ? 'hidden' : '';
  });

  document.querySelectorAll('.mobile-nav a').forEach((a) => {
    a.addEventListener('click', () => {
      mobileNav?.classList.remove('is-open');
      toggle?.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    });
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(251, 248, 243, 0.78);
    backdrop-filter: saturate(140%) blur(14px);
    -webkit-backdrop-filter: saturate(140%) blur(14px);
    border-bottom: 1px solid transparent;
    transition: background 0.25s, border-color 0.25s, box-shadow 0.25s;
  }
  .site-header.is-scrolled {
    background: rgba(255, 255, 255, 0.92);
    border-bottom-color: var(--slate-200);
    box-shadow: var(--shadow-sm);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding-block: 0.9rem;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--navy-900);
  }
  .brand-logo {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    object-fit: cover;
    background: white;
    padding: 4px;
    box-shadow: var(--shadow-sm);
  }
  .brand-text { display: flex; flex-direction: column; line-height: 1; }
  .brand-name {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--navy-900);
  }
  .brand-motto {
    margin-top: 3px;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--teal-600);
  }

  .primary-nav ul {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .nav-link {
    display: inline-block;
    padding: 0.5rem 0.85rem;
    color: var(--slate-700);
    font-weight: 500;
    font-size: 0.94rem;
    border-radius: 8px;
    position: relative;
  }
  .nav-link:hover { color: var(--navy-900); background: rgba(15, 46, 92, 0.04); }
  .nav-link.is-active { color: var(--navy-900); }
  .nav-link.is-active::after {
    content: "";
    position: absolute;
    left: 50%;
    bottom: 2px;
    width: 22px;
    height: 2px;
    background: var(--teal-600);
    border-radius: 2px;
    transform: translateX(-50%);
  }

  .header-cta {
    display: flex;
    align-items: center;
    gap: 0.9rem;
  }
  .phone-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--navy-900);
  }
  .phone-link:hover { color: var(--teal-700); }
  .btn-sm { padding: 0.6rem 1.1rem; font-size: 0.86rem; }

  .menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: space-between;
    width: 26px;
    height: 20px;
    padding: 0;
  }
  .menu-toggle span {
    width: 100%;
    height: 2px;
    background: var(--navy-900);
    border-radius: 2px;
    transition: transform 0.2s, opacity 0.2s;
  }
  .menu-toggle[aria-expanded="true"] span:nth-child(1) { transform: translateY(9px) rotate(45deg); }
  .menu-toggle[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
  .menu-toggle[aria-expanded="true"] span:nth-child(3) { transform: translateY(-9px) rotate(-45deg); }

  .mobile-nav {
    display: none;
    background: white;
    border-top: 1px solid var(--slate-200);
  }
  .mobile-nav.is-open { display: block; }
  .mobile-nav ul {
    list-style: none;
    padding: 1rem;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .mobile-nav .nav-link { display: block; padding: 0.85rem 1rem; font-size: 1rem; }

  @media (max-width: 1024px) {
    .primary-nav, .phone-link { display: none; }
    .menu-toggle { display: flex; }
    .brand-motto { display: none; }
  }
  @media (max-width: 520px) {
    .header-cta .btn-sm { display: none; }
  }
</style>
