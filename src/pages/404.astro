---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Page not found" noIndex>
  <section class="notfound">
    <div class="container inner">
      <span class="motto">Error 404</span>
      <h1>This page is off the map.</h1>
      <p class="lede">
        The page you are looking for has moved or never existed. Head back to our homepage or reach
        out to the team — we'll get you where you're going.
      </p>
      <div class="cta">
        <a href="/" class="btn btn-primary">Back to home</a>
        <a href="/contact" class="btn btn-ghost">Contact us</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .notfound { padding-block: clamp(5rem, 12vw, 9rem); background: var(--sand-50); }
  .inner { max-width: 640px; text-align: center; margin-inline: auto; }
  .inner .motto { display: inline-block; margin-bottom: 1rem; }
  .inner h1 { font-size: clamp(2.5rem, 6vw, 4rem); margin-bottom: 1rem; }
  .cta { display: flex; gap: 0.75rem; justify-content: center; margin-top: 2rem; flex-wrap: wrap; }
</style>
