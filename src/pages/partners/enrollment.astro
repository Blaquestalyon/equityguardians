---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PartnerRibbon from '../../components/PartnerRibbon.astro';

const partner = (Astro.locals as any).partner as { name: string } | null;
const displayName = partner?.name ?? 'Partner';
---

<BaseLayout
  title="Partner Realtor Enrollment"
  description="One-time enrollment for affiliated Equity Guardians Partner Realtors."
  noIndex={true}
>
  <PartnerRibbon name={displayName} />

  <section class="en-hero">
    <div class="container">
      <nav class="crumbs" aria-label="Breadcrumb">
        <a href="/partners/hub">Resource Shop</a>
        <span aria-hidden="true">/</span>
        <a href="/partners/texas">Texas</a>
        <span aria-hidden="true">/</span>
        <span>Enrollment</span>
      </nav>

      <span class="eyebrow">Company-wide · Form ID EG-ENROLL-US-v1.0</span>
      <h1>Partner Realtor Enrollment Form</h1>
      <p class="lede">
        Complete this once to enroll as an Equity Guardians Partner Realtor. It collects your
        information only. Your Partner Realtor Agreement is signed separately. Fields marked with
        an asterisk (*) are required.
      </p>
    </div>
  </section>

  <section class="en-form-section" id="enrollment-form">
    <div class="container form-container">

      <div class="form-letterhead">
        <div class="letterhead-left">
          <div class="lh-logo">
            <img src="/logo-mark.png" alt="" width="48" height="48" />
            <div>
              <div class="lh-name">EQUITY GUARDIANS</div>
              <div class="lh-motto">SAVE · EARN · PROTECT</div>
            </div>
          </div>
        </div>
        <div class="letterhead-right">
          <div class="lh-title">PARTNER REALTOR ENROLLMENT</div>
          <div class="lh-sub">Company-wide · Form ID: EG-ENROLL-US-v1.0</div>
        </div>
      </div>

      <div class="form-guidance">
        <h3>Before you begin</h3>
        <p>
          This form collects your identity, brokerage, and practice profile. Your Partner Realtor
          Agreement is a separate document, signed elsewhere. Enter the Agreement version you have
          been sent (for example, EG-PRA-TX-v1.0) in Section E so we can match this enrollment to
          the correct signed agreement.
        </p>
        <p class="legend">
          Have on hand: your license number, license expiration, brokerage details, sponsoring
          broker contact info, and the states and counties you serve.
        </p>
      </div>

      <form
        id="enrollment-form-el"
        class="intake-form"
        method="post"
        action="/api/partners/intake/enrollment"
        enctype="multipart/form-data"
        novalidate
      >

        <!-- ==================== SECTION A ==================== -->
        <fieldset class="section">
          <legend>
            <span class="section-letter">A</span>
            <span class="section-title">Submission &amp; Partner Tracking</span>
          </legend>

          <div class="row">
            <div class="field col-6">
              <label for="eg_partner_id">EG Partner ID <span class="tag optional">Office use</span></label>
              <input id="eg_partner_id" name="eg_partner_id" type="text" placeholder="Leave blank if you don't have one" />
            </div>
            <div class="field col-6">
              <label for="enrollment_date">Enrollment date <span class="tag optional">Office use</span></label>
              <input id="enrollment_date" name="enrollment_date" type="date" />
            </div>
          </div>

          <div class="row">
            <div class="field col-6">
              <label for="form_completed_date">Date form completed <span class="req">*</span></label>
              <input id="form_completed_date" name="form_completed_date" type="date" required />
            </div>
            <div class="field col-6">
              <label for="referral_source">How did you hear about Equity Guardians?</label>
              <input id="referral_source" name="referral_source" type="text" />
            </div>
          </div>
        </fieldset>

        <!-- ==================== SECTION B ==================== -->
        <fieldset class="section">
          <legend>
            <span class="section-letter">B</span>
            <span class="section-title">Agent Identity &amp; Contact</span>
          </legend>

          <div class="row">
            <div class="field col-12">
              <label for="agent_full_name">Agent full name <span class="req">*</span></label>
              <input id="agent_full_name" name="agent_full_name" type="text" required value={displayName} />
            </div>
          </div>

          <div class="row">
            <div class="field col-6">
              <label for="agent_license_number">Real estate license number <span class="req">*</span></label>
              <input id="agent_license_number" name="agent_license_number" type="text" required />
            </div>
            <div class="field col-3">
              <label for="license_state">License state(s) <span class="req">*</span></label>
              <input id="license_state" name="license_state" type="text" required placeholder="e.g. TX" />
            </div>
            <div class="field col-3">
              <label for="license_expiration_date">License expiration <span class="req">*</span></label>
              <input id="license_expiration_date" name="license_expiration_date" type="date" required />
            </div>
          </div>

          <div class="row">
            <div class="field col-4">
              <label for="license_type">License type <span class="req">*</span></label>
              <select id="license_type" name="license_type" required>
                <option value="">Select one</option>
                <option value="Salesperson">Salesperson</option>
                <option value="Broker">Broker</option>
                <option value="Broker Associate">Broker Associate</option>
              </select>
            </div>
            <div class="field col-4">
              <label for="years_licensed">Years licensed</label>
              <input id="years_licensed" name="years_licensed" type="number" min="0" step="1" />
            </div>
            <div class="field col-4">
              <label for="preferred_contact_method">Preferred contact</label>
              <select id="preferred_contact_method" name="preferred_contact_method">
                <option value="">Select one</option>
                <option value="Email">Email</option>
                <option value="Phone">Phone</option>
                <option value="Text">Text</option>
              </select>
            </div>
          </div>

          <div class="row">
            <div class="field col-6">
              <label for="agent_email">Email <span class="req">*</span></label>
              <input id="agent_email" name="agent_email" type="email" inputmode="email" required />
            </div>
            <div class="field col-6">
              <label for="agent_phone">Phone <span class="req">*</span></label>
              <input id="agent_phone" name="agent_phone" type="tel" inputmode="tel" required />
            </div>
          </div>

          <div class="row">
            <div class="field col-12">
              <label for="agent_mailing_address">Mailing address <span class="req">*</span></label>
              <input id="agent_mailing_address" name="agent_mailing_address" type="text" required />
            </div>
          </div>
        </fieldset>

        <!-- ==================== SECTION C ==================== -->
        <fieldset class="section">
          <legend>
            <span class="section-letter">C</span>
            <span class="section-title">Brokerage &amp; Sponsoring Broker</span>
          </legend>

          <div class="row">
            <div class="field col-8">
              <label for="brokerage_name">Brokerage name <span class="req">*</span></label>
              <input id="brokerage_name" name="brokerage_name" type="text" required />
            </div>
            <div class="field col-4">
              <label for="brokerage_license_number">Brokerage license #</label>
              <input id="brokerage_license_number" name="brokerage_license_number" type="text" />
            </div>
          </div>

          <div class="row">
            <div class="field col-12">
              <label for="brokerage_address">Brokerage address <span class="req">*</span></label>
              <input id="brokerage_address" name="brokerage_address" type="text" required />
            </div>
          </div>

          <div class="row">
            <div class="field col-8">
              <label for="sponsoring_broker_name">Sponsoring broker name <span class="req">*</span></label>
              <input id="sponsoring_broker_name" name="sponsoring_broker_name" type="text" required />
            </div>
            <div class="field col-4">
              <label for="sponsoring_broker_license_number">Sponsoring broker license #</label>
              <input id="sponsoring_broker_license_number" name="sponsoring_broker_license_number" type="text" />
            </div>
          </div>

          <div class="row">
            <div class="field col-6">
              <label for="sponsoring_broker_email">Sponsoring broker email <span class="req">*</span></label>
              <input id="sponsoring_broker_email" name="sponsoring_broker_email" type="email" inputmode="email" required />
            </div>
            <div class="field col-6">
              <label for="sponsoring_broker_phone">Sponsoring broker phone <span class="req">*</span></label>
              <input id="sponsoring_broker_phone" name="sponsoring_broker_phone" type="tel" inputmode="tel" required />
            </div>
          </div>

          <div class="row">
            <div class="field col-8">
              <label for="contracting_entity_name">Contracting party (legal name on the Partner Realtor Agreement) <span class="req">*</span></label>
              <input id="contracting_entity_name" name="contracting_entity_name" type="text" required />
            </div>
            <div class="field col-4">
              <label for="contracting_entity_type">Entity type</label>
              <select id="contracting_entity_type" name="contracting_entity_type">
                <option value="">Select one</option>
                <option value="Individual">Individual</option>
                <option value="LLC">LLC</option>
                <option value="Team">Team</option>
                <option value="Brokerage">Brokerage</option>
              </select>
            </div>
          </div>
        </fieldset>

        <!-- ==================== SECTION D ==================== -->
        <fieldset class="section">
          <legend>
            <span class="section-letter">D</span>
            <span class="section-title">Practice Profile &amp; Markets Served</span>
          </legend>

          <div class="row">
            <div class="field col-8">
              <label for="states_served">States served <span class="req">*</span></label>
              <input id="states_served" name="states_served" type="text" required placeholder="e.g. TX, LA" />
            </div>
            <div class="field col-4">
              <label for="practice_role">Practice role</label>
              <select id="practice_role" name="practice_role">
                <option value="">Select one</option>
                <option value="Individual agent">Individual agent</option>
                <option value="Team lead">Team lead</option>
                <option value="Broker-owner">Broker-owner</option>
              </select>
            </div>
          </div>

          <div class="row">
            <div class="field col-12">
              <label for="counties_markets_served">Counties / markets served <span class="req">*</span></label>
              <input id="counties_markets_served" name="counties_markets_served" type="text" required placeholder="e.g. Harris, Fort Bend, Montgomery" />
            </div>
          </div>

          <div class="row">
            <div class="field col-6">
              <label for="primary_mls_board">Primary MLS / board</label>
              <input id="primary_mls_board" name="primary_mls_board" type="text" />
            </div>
            <div class="field col-6">
              <label for="estimated_annual_closings">Estimated annual closings</label>
              <input id="estimated_annual_closings" name="estimated_annual_closings" type="number" min="0" step="1" />
            </div>
          </div>
        </fieldset>

        <!-- ==================== SECTION E ==================== -->
        <fieldset class="section">
          <legend>
            <span class="section-letter">E</span>
            <span class="section-title">Agreement, Consents &amp; Signature</span>
          </legend>

          <div class="row">
            <div class="field col-12">
              <label class="checkbox">
                <input type="checkbox" id="partner_agreement_ack" name="partner_agreement_ack" value="Yes" required />
                <span>I have read and agree to the Equity Guardians Partner Realtor Agreement. <span class="req">*</span></span>
              </label>
            </div>
          </div>

          <div class="row">
            <div class="field col-12">
              <label for="partner_agreement_version">Partner Realtor Agreement version signed <span class="req">*</span></label>
              <input id="partner_agreement_version" name="partner_agreement_version" type="text" required placeholder="e.g. EG-PRA-TX-v1.0" />
            </div>
          </div>

          <div class="row">
            <div class="field col-12">
              <label class="checkbox">
                <input type="checkbox" id="terms_privacy_ack" name="terms_privacy_ack" value="Yes" required />
                <span>I agree to the Equity Guardians <a href="/terms" target="_blank" rel="noopener">Terms of Service</a> and <a href="/privacy" target="_blank" rel="noopener">Privacy Policy</a>. <span class="req">*</span></span>
              </label>
            </div>
          </div>

          <div class="row">
            <div class="field col-6">
              <label class="checkbox">
                <input type="checkbox" name="marketing_optin" value="Yes" />
                <span>Opt in to co-branded marketing materials.</span>
              </label>
            </div>
            <div class="field col-6">
              <label class="checkbox">
                <input type="checkbox" id="cobrand_assets_provided" name="cobrand_assets_provided" value="Yes" />
                <span>Headshot / logo provided for co-branding.</span>
              </label>
            </div>
          </div>

          <div class="row cobrand-uploads" id="cobrand-uploads" hidden>
            <div class="field col-6">
              <label for="headshot_file">Headshot <span class="tag optional">Optional</span></label>
              <input
                id="headshot_file"
                name="headshot_file"
                type="file"
                accept="image/jpeg,image/png,image/webp"
                data-max-mb="5"
              />
              <p class="hint">JPG, PNG, or WebP. Up to 5 MB.</p>
            </div>
            <div class="field col-6">
              <label for="logo_file">Brokerage logo <span class="tag optional">Optional</span></label>
              <input
                id="logo_file"
                name="logo_file"
                type="file"
                accept="image/jpeg,image/png,image/webp"
                data-max-mb="5"
              />
              <p class="hint">JPG, PNG, or WebP. Up to 5 MB. Transparent PNG preferred.</p>
            </div>
          </div>

          <div class="row">
            <div class="field col-8">
              <label for="agent_signature">Agent signature (typed) <span class="req">*</span></label>
              <input id="agent_signature" name="agent_signature" type="text" required placeholder="Type your full legal name" />
            </div>
            <div class="field col-4">
              <label for="signature_date">Date <span class="req">*</span></label>
              <input id="signature_date" name="signature_date" type="date" required />
            </div>
          </div>

          <p class="signature-note">
            Typing your full name above serves as your signature for this enrollment record. Your
            Partner Realtor Agreement itself is signed separately as a countersigned PDF.
          </p>
        </fieldset>

        <!-- ==================== ACTIONS ==================== -->
        <div class="form-footer">
          <div class="confidential-note">
            Confidential. Equity Guardians partner enrollment. Duplicate submissions are versioned
            in our records rather than overwritten, so it is safe to resubmit if a field needs
            correction.
          </div>
          <div class="form-actions">
            <button type="button" class="btn btn-ghost" id="print-blank">Print blank form</button>
            <button type="submit" class="btn btn-primary" id="submit-btn">Submit enrollment</button>
          </div>
          <div class="form-status" role="status" aria-live="polite" id="form-status"></div>
        </div>
      </form>

      <!-- Confirmation view (revealed on success) -->
      <div class="confirmation" id="confirmation" hidden>
        <div class="check-icon" aria-hidden="true">
          <svg viewBox="0 0 48 48" width="56" height="56"><circle cx="24" cy="24" r="22" fill="none" stroke="currentColor" stroke-width="2"/><path d="M14 24l7 7 13-14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <h2>Enrollment submitted.</h2>
        <p class="confirmation-lede">
          Thank you, <span id="conf-name">{displayName}</span>. Your Partner Realtor enrollment
          has been recorded. Save the reference below in case you need to contact us about this
          submission.
        </p>
        <dl class="confirmation-meta">
          <div><dt>Form ID</dt><dd>EG-ENROLL-US-v1.0</dd></div>
          <div><dt>Submitted at</dt><dd id="conf-time"></dd></div>
          <div><dt>Reference</dt><dd id="conf-ref">Recorded</dd></div>
          <div><dt>Version</dt><dd id="conf-version">v1</dd></div>
        </dl>
        <p class="confirmation-note" id="conf-duplicate-note" hidden>
          We already had an enrollment on file with matching license number or email, so this
          submission was saved as a new version. Your prior submissions were preserved for our
          records.
        </p>
        <div class="confirmation-actions">
          <button type="button" class="btn btn-primary" id="print-submitted">Print / save as PDF</button>
          <a href="/partners/texas" class="btn btn-ghost">Back to Texas resources</a>
          <button type="button" class="btn btn-ghost" id="submit-another">Submit another enrollment</button>
        </div>
      </div>

    </div>
  </section>
</BaseLayout>

<script is:inline>
  (function () {
    const form = document.getElementById('enrollment-form-el');
    if (!form) return;
    const status = document.getElementById('form-status');
    const submitBtn = document.getElementById('submit-btn');
    const printBlank = document.getElementById('print-blank');
    const confirmation = document.getElementById('confirmation');
    const confName = document.getElementById('conf-name');
    const confTime = document.getElementById('conf-time');
    const confRef = document.getElementById('conf-ref');
    const confVersion = document.getElementById('conf-version');
    const confDupNote = document.getElementById('conf-duplicate-note');
    const printSubmitted = document.getElementById('print-submitted');
    const submitAnother = document.getElementById('submit-another');

    // Prefill today's date on the two date-of-completion fields for convenience.
    const today = new Date().toISOString().slice(0, 10);
    ['form_completed_date', 'signature_date'].forEach((n) => {
      const el = form.elements.namedItem(n);
      if (el && !el.value) el.value = today;
    });

    // Show the file upload row only when the co-branding provider checkbox is on.
    const cobrandToggle = document.getElementById('cobrand_assets_provided');
    const cobrandUploads = document.getElementById('cobrand-uploads');
    const headshotInput = document.getElementById('headshot_file');
    const logoInput = document.getElementById('logo_file');
    function syncCobrandUploads() {
      if (!cobrandToggle || !cobrandUploads) return;
      const on = cobrandToggle.checked;
      cobrandUploads.hidden = !on;
      if (!on) {
        // Clear pending file selections so nothing is uploaded if user un-opts.
        if (headshotInput) headshotInput.value = '';
        if (logoInput) logoInput.value = '';
      }
    }
    if (cobrandToggle) {
      cobrandToggle.addEventListener('change', syncCobrandUploads);
      syncCobrandUploads();
    }

    if (printBlank) {
      printBlank.addEventListener('click', () => {
        document.body.classList.add('printing-form');
        window.print();
        setTimeout(() => document.body.classList.remove('printing-form'), 500);
      });
    }

    if (printSubmitted) {
      printSubmitted.addEventListener('click', () => {
        document.body.classList.add('printing-submitted');
        window.print();
        setTimeout(() => document.body.classList.remove('printing-submitted'), 500);
      });
    }

    if (submitAnother) {
      submitAnother.addEventListener('click', () => {
        confirmation.hidden = true;
        form.hidden = false;
        const kept = form.agent_full_name?.value;
        form.reset();
        if (kept && form.agent_full_name) form.agent_full_name.value = kept;
        ['form_completed_date', 'signature_date'].forEach((n) => {
          const el = form.elements.namedItem(n);
          if (el && !el.value) el.value = today;
        });
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Submit enrollment';
        }
        if (status) {
          status.textContent = '';
          status.className = 'form-status';
        }
        window.scrollTo({ top: form.offsetTop - 100, behavior: 'smooth' });
      });
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!status || !submitBtn) return;

      status.textContent = '';
      status.className = 'form-status';

      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }

      // Client-side guard: file size and type. Files are optional even when opted in.
      const MAX_MB = 5;
      const MAX_BYTES = MAX_MB * 1024 * 1024;
      const ALLOWED = ['image/jpeg', 'image/png', 'image/webp'];
      const filesToCheck = [
        { input: headshotInput, label: 'Headshot' },
        { input: logoInput, label: 'Brokerage logo' },
      ];
      for (const { input, label } of filesToCheck) {
        if (!input || !input.files || input.files.length === 0) continue;
        const f = input.files[0];
        if (f.size > MAX_BYTES) {
          status.textContent = label + ' is ' + (f.size / 1024 / 1024).toFixed(1) + ' MB. Please choose a file under ' + MAX_MB + ' MB.';
          status.className = 'form-status form-status-error';
          input.focus();
          return;
        }
        if (!ALLOWED.includes(f.type)) {
          status.textContent = label + ' must be JPG, PNG, or WebP.';
          status.className = 'form-status form-status-error';
          input.focus();
          return;
        }
      }

      submitBtn.disabled = true;
      submitBtn.textContent = 'Submitting…';

      try {
        const fd = new FormData(form);
        const res = await fetch('/api/partners/intake/enrollment', {
          method: 'POST',
          headers: { Accept: 'application/json' },
          body: fd,
        });
        const data = await res.json().catch(() => ({}));

        if (!res.ok) {
          if (res.status === 401) {
            status.innerHTML = 'Your session expired. <a href="/partners">Sign in again</a> to submit.';
          } else {
            status.textContent = data.error || 'Submission failed. Please try again.';
          }
          status.className = 'form-status form-status-error';
          submitBtn.disabled = false;
          submitBtn.textContent = 'Submit enrollment';
          return;
        }

        if (confName) confName.textContent = fd.get('agent_full_name') || 'Partner';
        if (confTime) confTime.textContent = new Date().toLocaleString();
        if (confRef && data.reference) confRef.textContent = data.reference;
        if (confVersion) confVersion.textContent = 'v' + (data.version || 1);
        if (confDupNote) confDupNote.hidden = !data.isDuplicate;

        confirmation.hidden = false;
        form.hidden = true;
        window.scrollTo({ top: (confirmation.offsetTop || 0) - 100, behavior: 'smooth' });
      } catch (err) {
        status.textContent = 'Network error. Please try again in a moment.';
        status.className = 'form-status form-status-error';
        submitBtn.disabled = false;
        submitBtn.textContent = 'Submit enrollment';
      }
    });
  })();
</script>

<style>
  /* Hero */
  .en-hero {
    background: linear-gradient(180deg, #FBF7EE 0%, #FFFFFF 100%);
    padding: 3.5rem 0 2rem;
    border-bottom: 1px solid var(--slate-200);
  }
  .crumbs {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--slate-500);
    margin-bottom: 1.25rem;
    display: flex;
    gap: 0.5rem;
    align-items: center;
    flex-wrap: wrap;
  }
  .crumbs a { color: var(--slate-500); text-decoration: none; border-bottom: 1px solid transparent; }
  .crumbs a:hover { color: var(--navy-900); border-color: var(--teal-500); }
  .crumbs span[aria-hidden] { opacity: 0.5; }

  .en-hero .eyebrow {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--teal-700);
    font-weight: 600;
    padding-bottom: 0.55rem;
    border-bottom: 2px solid var(--teal-500);
    margin-bottom: 1rem;
  }
  .en-hero h1 {
    font-family: var(--font-serif);
    font-size: clamp(1.9rem, 3.6vw, 2.6rem);
    color: var(--navy-900);
    margin: 0 0 0.75rem;
    line-height: 1.1;
    max-width: 22ch;
    letter-spacing: -0.01em;
  }
  .en-hero .lede {
    max-width: 62ch;
    color: var(--slate-600);
    line-height: 1.6;
