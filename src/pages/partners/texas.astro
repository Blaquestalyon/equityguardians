---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PartnerRibbon from '../../components/PartnerRibbon.astro';
import { findStateBySlug } from '../../data/partner-states';
import { texasFlyers } from '../../data/partner-media';

const partner = (Astro.locals as any).partner as { name: string } | null;
const displayName = partner?.name ?? 'Partner';
const state = findStateBySlug('texas')!;

// Total resource count: operational forms (from state.resources) + promotional flyers.
const totalResources = state.resources.length + texasFlyers.length;
---

<BaseLayout
  title="Texas · Partner Resources"
  description="Texas resources for affiliated Buyer's Realtors. Member intake, closing paperwork, and more."
  noIndex={true}
>
  <PartnerRibbon name={displayName} />

  <section class="tx-hero">
    <div class="container">
      <nav class="crumbs" aria-label="Breadcrumb">
        <a href="/partners/hub">Resource Shop</a>
        <span aria-hidden="true">/</span>
        <span>Texas</span>
      </nav>

      <span class="eyebrow">Texas · {totalResources} {totalResources === 1 ? 'resource' : 'resources'} available</span>
      <h1>Texas resources for affiliated Buyer's Realtors.</h1>
      <p class="lede">
        Everything you need to bring a Texas closing into Equity Guardians. All forms are stamped
        with your name automatically. Fill out one intake form per closing, working only from the
        paperwork already in hand.
      </p>
    </div>
  </section>

  <section class="tx-shelf">
    <div class="container">

      {/* ============ CATEGORY 1: Operational Forms & Documents ============ */}
      <div class="category-header">
        <span class="category-eyebrow">Category</span>
        <h2>Operational Forms &amp; Documents</h2>
        <p class="category-note">Forms, checklists, and paperwork used to bring a closing into Equity Guardians.</p>
      </div>

      <div class="resource-card">
        <div class="resource-meta">
          <span class="resource-kind">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14" aria-hidden="true"><path d="M14 3H6a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><path d="M14 3v6h6"/><path d="M8 13h8M8 17h5"/></svg>
            Form
          </span>
          <span class="resource-id">EG-INTAKE-TX-v1.0</span>
        </div>
        <h3 class="resource-title">Texas Member Intake Form</h3>
        <p class="resource-desc">
          Fill out once per closing, working only from the paperwork already in hand. Every field
          is tagged with its source: CD (Closing Disclosure), PC (Executed Purchase Contract),
          MLS (MLS listing), R (You). Fields marked Optional may be left blank.
        </p>
        <div class="resource-actions">
          <a href="/partners/texas/intake" class="resource-open">
            Open the form
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14" aria-hidden="true"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
          </a>
          <a
            href="/partners/texas/forms/EG-Texas-Member-Intake-Form-v1.0.pdf"
            class="resource-download"
            download="EG-Texas-Member-Intake-Form-v1.0.pdf"
          >
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="15" height="15" aria-hidden="true"><path d="M14 3v5h5"/><path d="M6 3h8l6 6v10a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z"/><path d="M12 12v6" stroke-linecap="round"/><path d="M9 15l3 3 3-3" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Download blank PDF
          </a>
        </div>
      </div>

      <div class="resource-card">
        <div class="resource-meta">
          <span class="resource-kind">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14" aria-hidden="true"><path d="M14 3H6a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><path d="M14 3v6h6"/><path d="M8 13h8M8 17h5"/></svg>
            Form
          </span>
          <span class="resource-id">EG-ENROLL-US-v1.0</span>
        </div>
        <h3 class="resource-title">Partner Realtor Enrollment Form</h3>
        <p class="resource-desc">
          One-time enrollment for affiliated Buyer's Realtors. Complete this once to establish
          your Partner Realtor record. Your Partner Realtor Agreement is signed separately. This
          form is company-wide and is surfaced here while Texas is the first live state.
        </p>
        <div class="resource-actions">
          <a href="/partners/enrollment" class="resource-open">
            Open the form
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14" aria-hidden="true"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
          </a>
          <a
            href="/partners/texas/forms/EG-Partner-Realtor-Enrollment-Form-v1.0.pdf"
            class="resource-download"
            download="EG-Partner-Realtor-Enrollment-Form-v1.0.pdf"
          >
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="15" height="15" aria-hidden="true"><path d="M14 3v5h5"/><path d="M6 3h8l6 6v10a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z"/><path d="M12 12v6" stroke-linecap="round"/><path d="M9 15l3 3 3-3" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Download blank PDF
          </a>
        </div>
      </div>

      <div class="resource-card">
        <div class="resource-meta">
          <span class="resource-kind">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14" aria-hidden="true"><path d="M14 3H6a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><path d="M14 3v6h6"/><path d="M8 13h8M8 17h5"/></svg>
            Document
          </span>
          <span class="resource-id">EG-BROKER-ACK-TX-v1.0</span>
        </div>
        <h3 class="resource-title">Sponsoring Broker Acknowledgment</h3>
        <p class="resource-desc">
          Broker-signed acknowledgment covering supervision, disclosure, and compensation terms
          for affiliated Buyer's Realtors. Download, sign, and return outside the portal.
        </p>
        <div class="resource-actions">
          <a
            href="/partners/texas/forms/EG-Texas-Sponsoring-Broker-Acknowledgment-v1.0.pdf"
            class="resource-download"
            download="EG-Texas-Sponsoring-Broker-Acknowledgment-v1.0.pdf"
          >
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="15" height="15" aria-hidden="true"><path d="M14 3v5h5"/><path d="M6 3h8l6 6v10a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z"/><path d="M12 12v6" stroke-linecap="round"/><path d="M9 15l3 3 3-3" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Download blank PDF
          </a>
        </div>
      </div>

      {/* ============ CATEGORY 2: Promotional Media ============ */}
      <div class="category-header category-header-2">
        <span class="category-eyebrow">Category</span>
        <h2>Promotional Media</h2>
        <p class="category-note">Flyers and marketing materials for use with buyers. Same artwork available for digital, professional print, and social use.</p>
      </div>

      <div class="flyer-grid">
        {texasFlyers.map((flyer) => (
          <article class="flyer-card">
            <div class="flyer-cover">
              <picture>
                {flyer.cover.thumbWebp && <source srcset={flyer.cover.thumbWebp} type="image/webp" />}
                <img src={flyer.cover.thumb} alt={flyer.cover.alt} loading="lazy" />
              </picture>
            </div>
            <div class="flyer-body">
              <div class="flyer-meta">
                <span class="resource-kind">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/></svg>
                  Flyer
                </span>
                <span class="flyer-audience">For {flyer.audience.toLowerCase()}s</span>
              </div>
              <h3 class="resource-title">{flyer.name}</h3>
              <p class="flyer-focus">{flyer.focus}</p>

              <ul class="variant-list">
                {flyer.variants.map((v) => (
                  <li class={`variant variant-${v.kind}`}>
                    <a href={v.href} class="variant-link" download={v.filename}>
                      <span class="variant-icon" aria-hidden="true">
                        {v.kind === 'digital' && (
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><rect x="3" y="4" width="18" height="12" rx="2"/><path d="M8 20h8M12 16v4"/></svg>
                        )}
                        {v.kind === 'print' && (
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><path d="M6 9V4h12v5"/><rect x="3" y="9" width="18" height="8" rx="2"/><rect x="6" y="14" width="12" height="7"/></svg>
                        )}
                        {v.kind === 'image' && (
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="10" r="1.5" fill="currentColor"/><path d="M21 17l-5-6-4 5-2-2-4 5"/></svg>
                        )}
                      </span>
                      <span class="variant-text">
                        <span class="variant-label">
                          {v.label}
                          {v.fileSize && <span class="variant-size">{v.fileSize}</span>}
                        </span>
                        {v.note && <span class="variant-note">{v.note}</span>}
                      </span>
                      <span class="variant-arrow" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M12 5v14M5 12l7 7 7-7" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      </span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </article>
        ))}
      </div>

      <p class="shelf-footer-note">More Texas resources will appear here as they are released.</p>
    </div>
  </section>

</BaseLayout>


<style>
  /* ---------- Hero ---------- */
  .tx-hero {
    background: linear-gradient(180deg, #FBF7EE 0%, #FFFFFF 100%);
    padding: 3.5rem 0 2rem;
    border-bottom: 1px solid var(--slate-200);
  }
  .crumbs {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--slate-500);
    margin-bottom: 1.25rem;
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }
  .crumbs a { color: var(--slate-500); text-decoration: none; border-bottom: 1px solid transparent; }
  .crumbs a:hover { color: var(--navy-900); border-color: var(--teal-500); }
  .crumbs span[aria-hidden] { opacity: 0.5; }

  .tx-hero .eyebrow {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--teal-700);
    font-weight: 600;
    padding-bottom: 0.55rem;
    border-bottom: 2px solid var(--teal-500);
    margin-bottom: 1rem;
  }
  .tx-hero h1 {
    font-family: var(--font-serif);
    font-size: clamp(1.9rem, 3.6vw, 2.6rem);
    color: var(--navy-900);
    margin: 0 0 0.75rem;
    line-height: 1.1;
    max-width: 22ch;
    letter-spacing: -0.01em;
  }
  .tx-hero .lede {
    max-width: 60ch;
    color: var(--slate-600);
    line-height: 1.6;
    margin: 0;
  }

  /* ---------- Resource shelf: category headers ---------- */
  .tx-shelf { padding: 2rem 0 3rem; }
  .category-header { margin-bottom: 1.25rem; }
  .category-header-2 { margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--slate-200); }
  .category-eyebrow {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--teal-700);
    font-weight: 700;
    margin-bottom: 0.5rem;
  }
  .category-header h2 {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    color: var(--navy-900);
    margin: 0 0 0.4rem;
    letter-spacing: -0.005em;
  }
  .category-note { color: var(--slate-600); font-size: 0.95rem; margin: 0; max-width: 60ch; line-height: 1.55; }
  .shelf-footer-note { color: var(--slate-500); font-size: 0.88rem; margin: 2rem 0 0; font-style: normal; }

  /* ---------- Flyer card ---------- */
  .flyer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  .flyer-card {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 0;
    max-width: 900px;
    background: white;
    border: 1px solid var(--slate-200);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(10, 25, 48, 0.04);
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .flyer-card:hover {
    box-shadow: 0 12px 32px rgba(10, 25, 48, 0.1);
    transform: translateY(-2px);
  }
  .flyer-cover {
    background: #F1F3F6;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    border-right: 1px solid var(--slate-200);
  }
  .flyer-cover img {
    display: block;
    width: 100%;
    height: auto;
    max-width: 220px;
    border-radius: 6px;
    box-shadow: 0 4px 16px rgba(10, 25, 48, 0.12);
  }
  .flyer-body { padding: 1.5rem 1.75rem; }
  .flyer-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.85rem;
    flex-wrap: wrap;
  }
  .flyer-audience {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--slate-500);
    font-weight: 600;
  }
  .flyer-focus {
    color: var(--slate-600);
    font-size: 0.95rem;
    line-height: 1.55;
    margin: 0 0 1.15rem;
    max-width: 55ch;
  }

  /* Variant download list */
  .variant-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .variant-link {
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
    padding: 0.75rem 1rem;
    border: 1px solid var(--slate-200);
    border-radius: 10px;
    background: white;
    text-decoration: none;
    color: var(--navy-900);
    transition: border-color 0.2s, background 0.2s, transform 0.15s, box-shadow 0.2s;
  }
  .variant-link:hover {
    border-color: var(--teal-500);
    background: #F5FBFB;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(10, 25, 48, 0.06);
  }
  .variant-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: rgba(20, 184, 166, 0.12);
    color: var(--teal-700);
    border-radius: 8px;
    flex-shrink: 0;
  }
  .variant-print .variant-icon { background: rgba(10, 25, 48, 0.08); color: var(--navy-900); }
  .variant-image .variant-icon { background: rgba(234, 179, 8, 0.14); color: #A16207; }
  .variant-text { flex: 1; display: flex; flex-direction: column; gap: 0.15rem; min-width: 0; }
  .variant-label {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    font-weight: 600;
    font-size: 0.94rem;
    color: var(--navy-900);
  }
  .variant-size {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    color: var(--slate-500);
    font-weight: 500;
  }
  .variant-note {
    font-size: 0.82rem;
    color: var(--slate-600);
    line-height: 1.45;
  }
  .variant-arrow {
    display: inline-flex;
    align-items: center;
    color: var(--slate-500);
    align-self: center;
    flex-shrink: 0;
    transition: color 0.2s, transform 0.2s;
  }
  .variant-link:hover .variant-arrow {
    color: var(--teal-700);
    transform: translateY(2px);
  }

  @media (max-width: 720px) {
    .flyer-card { grid-template-columns: 1fr; }
    .flyer-cover { border-right: 0; border-bottom: 1px solid var(--slate-200); padding: 1.5rem; }
    .flyer-cover img { max-width: 180px; }
  }

  .resource-card {
    max-width: 720px;
    background: white;
    border: 1px solid var(--slate-200);
    border-radius: 16px;
    padding: 1.5rem 1.75rem;
    box-shadow: 0 2px 8px rgba(10, 25, 48, 0.04);
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .resource-card:hover {
    box-shadow: 0 12px 32px rgba(10, 25, 48, 0.1);
    transform: translateY(-2px);
  }
  .resource-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.85rem;
  }
  .resource-kind {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: rgba(20, 184, 166, 0.12);
    color: var(--teal-700);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-weight: 700;
    padding: 0.3rem 0.6rem;
    border-radius: 999px;
  }
  .resource-id {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    color: var(--slate-500);
  }
  .resource-title {
    font-family: var(--font-serif);
    font-size: 1.4rem;
    color: var(--navy-900);
    margin: 0 0 0.5rem;
  }
  .resource-desc {
    color: var(--slate-600);
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0 0 1.1rem;
  }
  .resource-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    align-items: center;
  }
  .resource-open {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: var(--navy-900);
    color: white;
    padding: 0.65rem 1.1rem;
    border-radius: 10px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.92rem;
    transition: background 0.2s, transform 0.15s;
  }
  .resource-open:hover { background: var(--navy-800); transform: translateY(-1px); }
  .resource-download {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    background: white;
    color: var(--navy-900);
    padding: 0.6rem 1.05rem;
    border-radius: 10px;
    border: 1px solid var(--slate-300, #cbd5e1);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.92rem;
    transition: border-color 0.2s, background 0.2s, transform 0.15s;
  }
  .resource-download:hover {
    border-color: var(--teal-500);
    background: #F5FBFB;
    transform: translateY(-1px);
  }
  .resource-download svg { color: var(--teal-700, #0f766e); }

</style>
