---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PartnerRibbon from '../../components/PartnerRibbon.astro';
import { findStateBySlug } from '../../data/partner-states';
import { texasFlyers } from '../../data/partner-media';

const partner = (Astro.locals as any).partner as { name: string } | null;
const displayName = partner?.name ?? 'Partner';
const state = findStateBySlug('texas')!;

// Total resource count: operational forms (from state.resources) + promotional flyers.
const totalResources = state.resources.length + texasFlyers.length;
---

<BaseLayout
  title="Texas · Partner Resources"
  description="Texas resources for affiliated Buyer's Realtors. Member intake, closing paperwork, and more."
  noIndex={true}
>
  <PartnerRibbon name={displayName} />

  <section class="tx-hero">
    <div class="container">
      <nav class="crumbs" aria-label="Breadcrumb">
        <a href="/partners/hub">Resource Shop</a>
        <span aria-hidden="true">/</span>
        <span>Texas</span>
      </nav>

      <span class="eyebrow">Texas · {totalResources} {totalResources === 1 ? 'resource' : 'resources'} available</span>
      <h1>Texas resources for affiliated Buyer's Realtors.</h1>
      <p class="lede">
        Everything you need to bring a Texas closing into Equity Guardians. All forms are stamped
        with your name automatically. Fill out one intake form per closing, working only from the
        paperwork already in hand.
      </p>
    </div>
  </section>

  <section class="tx-shelf">
    <div class="container">

      {/* ============ CATEGORY 1: Operational Forms & Documents ============ */}
      <div class="category-header">
        <span class="category-eyebrow">Category</span>
        <h2>Operational Forms &amp; Documents</h2>
        <p class="category-note">Forms, checklists, and paperwork used to bring a closing into Equity Guardians.</p>
      </div>

      <div class="resource-card">
        <div class="resource-meta">
          <span class="resource-kind">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14" aria-hidden="true"><path d="M14 3H6a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><path d="M14 3v6h6"/><path d="M8 13h8M8 17h5"/></svg>
            Form
          </span>
          <span class="resource-id">EG-INTAKE-TX-v1.0</span>
        </div>
        <h3 class="resource-title">Texas Member Intake Form</h3>
        <p class="resource-desc">
          Fill out once per closing, working only from the paperwork already in hand. Every field
          is tagged with its source: CD (Closing Disclosure), PC (Executed Purchase Contract),
          MLS (MLS listing), R (You). Fields marked Optional may be left blank.
        </p>
        <div class="resource-actions">
          <a href="#intake-form" class="resource-open">
            Open the form
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14" aria-hidden="true"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
          </a>
          <a
            href="/partners/texas/forms/EG-Texas-Member-Intake-Form-v1.0.pdf"
            class="resource-download"
            download="EG-Texas-Member-Intake-Form-v1.0.pdf"
          >
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="15" height="15" aria-hidden="true"><path d="M14 3v5h5"/><path d="M6 3h8l6 6v10a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z"/><path d="M12 12v6" stroke-linecap="round"/><path d="M9 15l3 3 3-3" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Download blank PDF
          </a>
        </div>
      </div>

      {/* ============ CATEGORY 2: Promotional Media ============ */}
      <div class="category-header category-header-2">
        <span class="category-eyebrow">Category</span>
        <h2>Promotional Media</h2>
        <p class="category-note">Flyers and marketing materials for use with buyers. Same artwork available for digital, professional print, and social use.</p>
      </div>

      <div class="flyer-grid">
        {texasFlyers.map((flyer) => (
          <article class="flyer-card">
            <div class="flyer-cover">
              <picture>
                {flyer.cover.thumbWebp && <source srcset={flyer.cover.thumbWebp} type="image/webp" />}
                <img src={flyer.cover.thumb} alt={flyer.cover.alt} loading="lazy" />
              </picture>
            </div>
            <div class="flyer-body">
              <div class="flyer-meta">
                <span class="resource-kind">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/></svg>
                  Flyer
                </span>
                <span class="flyer-audience">For {flyer.audience.toLowerCase()}s</span>
              </div>
              <h3 class="resource-title">{flyer.name}</h3>
              <p class="flyer-focus">{flyer.focus}</p>

              <ul class="variant-list">
                {flyer.variants.map((v) => (
                  <li class={`variant variant-${v.kind}`}>
                    <a href={v.href} class="variant-link" download={v.filename}>
                      <span class="variant-icon" aria-hidden="true">
                        {v.kind === 'digital' && (
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><rect x="3" y="4" width="18" height="12" rx="2"/><path d="M8 20h8M12 16v4"/></svg>
                        )}
                        {v.kind === 'print' && (
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><path d="M6 9V4h12v5"/><rect x="3" y="9" width="18" height="8" rx="2"/><rect x="6" y="14" width="12" height="7"/></svg>
                        )}
                        {v.kind === 'image' && (
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="10" r="1.5" fill="currentColor"/><path d="M21 17l-5-6-4 5-2-2-4 5"/></svg>
                        )}
                      </span>
                      <span class="variant-text">
                        <span class="variant-label">
                          {v.label}
                          {v.fileSize && <span class="variant-size">{v.fileSize}</span>}
                        </span>
                        {v.note && <span class="variant-note">{v.note}</span>}
                      </span>
                      <span class="variant-arrow" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M12 5v14M5 12l7 7 7-7" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      </span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </article>
        ))}
      </div>

      <p class="shelf-footer-note">More Texas resources will appear here as they are released.</p>
    </div>
  </section>

  <section class="tx-form-section" id="intake-form">
    <div class="container form-container">

      <!-- Fake letterhead so the printed page reads like the PDF -->
      <div class="form-letterhead">
        <div class="letterhead-left">
          <div class="lh-logo">
            <img src="/logo-mark.png" alt="" width="48" height="48" />
            <div>
              <div class="lh-name">EQUITY GUARDIANS</div>
              <div class="lh-motto">SAVE · EARN · PROTECT</div>
            </div>
          </div>
        </div>
        <div class="letterhead-right">
          <div class="lh-title">MEMBER INTAKE FORM</div>
          <div class="lh-sub">Texas · Form ID: EG-INTAKE-TX-v1.0</div>
        </div>
      </div>

      <div class="form-guidance">
        <h3>How to complete this form</h3>
        <p>
          Fill out one form per closing, working only from the paperwork already in hand. Every
          field is tagged with its source. Fields marked Optional may be left blank. Do not
          contact the buyer to complete this form. If an answer is not in these documents, leave
          it blank.
        </p>
        <p class="legend">
          <strong>CD</strong> = Closing Disclosure / settlement statement ·
          <strong>PC</strong> = Executed purchase contract ·
          <strong>MLS</strong> = MLS listing ·
          <strong>R</strong> = You (Realtor)
        </p>
      </div>

      <form id="intake-form-el" class="intake-form" method="post" action="/api/partners/intake/texas" novalidate>

        <!-- ==================== SECTION A ==================== -->
        <fieldset class="section">
          <legend>
            <span class="section-letter">A</span>
            <span class="section-title">Submission &amp; Deal Tracking</span>
          </legend>

          <div class="row">
            <div class="field col-12">
              <label for="referring_realtor">
                Referring Realtor <span class="req">*</span>
                <span class="tag">R</span>
              </label>
              <input id="referring_realtor" name="referring_realtor" type="text" required value={displayName} />
            </div>
          </div>

          <div class="row">
            <div class="field col-6">
              <label for="brokerage">Brokerage <span class="tag">R / PC</span></label>
              <input id="brokerage" name="brokerage" type="text" />
            </div>
            <div class="field col-6">
              <label for="eg_partner_id">EG Partner ID <span class="tag">EG</span></label>
              <input id="eg_partner_id" name="eg_partner_id" type="text" />
            </div>
          </div>

          <div class="row">
            <div class="field col-6">
              <label for="realtor_email">Realtor email <span class="tag">R</span></label>
              <input id="realtor_email" name="realtor_email" type="email" inputmode="email" />
            </div>
            <div class="field col-6">
              <label for="realtor_phone">Realtor phone <span class="tag">R</span></label>
              <input id="realtor_phone" name="realtor_phone" type="tel" inputmode="tel" />
            </div>
          </div>

          <div class="row">
            <div class="field col-6">
              <label for="closing_date">Closing date <span class="req">*</span> <span class="tag">CD</span></label>
              <input id="closing_date" name="closing_date" type="date" required />
            </div>
            <div class="field col-6">
              <label for="date_completed">Date form completed <span class="tag">R</span></label>
              <input id="date_completed" name="date_completed" type="date" />
            </div>
          </div>
        </fieldset>

        <!-- ==================== SECTION B ==================== -->
        <fieldset class="section">
          <legend>
            <span class="section-letter">B</span>
            <span class="section-title">Member Identity &amp; Contact</span>
          </legend>

          <div class="row">
            <div class="field col-12">
              <label for="member_1_name">
                Member 1 full name <span class="req">*</span>
                <span class="tag">CD / PC</span>
              </label>
              <input id="member_1_name" name="member_1_name" type="text" required />
            </div>
          </div>

          <div class="row">
            <div class="field col-12">
              <label for="member_2_name">Member 2 full name (if any) <span class="tag">CD / PC</span></label>
              <input id="member_2_name" name="member_2_name" type="text" />
            </div>
          </div>

          <div class="row">
            <div class="field col-8">
              <label for="additional_members">Additional members on title (names) <span class="tag">CD / PC</span></label>
              <input id="additional_members" name="additional_members" type="text" />
            </div>
            <div class="field col-4">
              <label for="buyers_on_title"># buyers on title <span class="tag">CD / PC</span></label>
              <input id="buyers_on_title" name="buyers_on_title" type="number" min="0" step="1" />
            </div>
          </div>

          <div class="row">
            <div class="field col-12">
              <label for="member_mailing_address">Member mailing address after closing <span class="tag">CD</span></label>
              <input id="member_mailing_address" name="member_mailing_address" type="text" />
            </div>
          </div>

          <div class="row">
            <div class="field col-6">
              <label for="member_email">Member email <span class="tag optional">Optional · R</span></label>
              <input id="member_email" name="member_email" type="email" inputmode="email" />
            </div>
            <div class="field col-6">
              <label for="member_phone">Member phone <span class="tag optional">Optional · R</span></label>
              <input id="member_phone" name="member_phone" type="tel" inputmode="tel" />
            </div>
          </div>
        </fieldset>

        <!-- ==================== SECTION C ==================== -->
        <fieldset class="section">
          <legend>
            <span class="section-letter">C</span>
            <span class="section-title">Property Profile</span>
          </legend>

          <div class="row">
            <div class="field col-12">
              <label for="property_street">
                Property street address <span class="req">*</span>
                <span class="tag">CD / PC / MLS</span>
              </label>
              <input id="property_street" name="property_street" type="text" required />
            </div>
          </div>

          <div class="row">
            <div class="field col-4">
              <label for="property_city">City <span class="tag">CD / PC / MLS</span></label>
              <input id="property_city" name="property_city" type="text" />
            </div>
            <div class="field col-4">
              <label for="property_county">County <span class="tag">CD / MLS</span></label>
              <input id="property_county" name="property_county" type="text" />
            </div>
            <div class="field col-2">
              <label for="property_state">State <span class="tag">CD</span></label>
              <input id="property_state" name="property_state" type="text" value="TX" maxlength="2" />
            </div>
            <div class="field col-2">
              <label for="property_zip">ZIP <span class="tag">CD / MLS</span></label>
              <input id="property_zip" name="property_zip" type="text" inputmode="numeric" maxlength="10" />
            </div>
          </div>

          <div class="row">
            <div class="field col-12">
              <label class="group-label">Property type <span class="tag">MLS / PC</span></label>
              <div class="radio-group" role="radiogroup" aria-label="Property type">
                <label class="radio">
                  <input type="radio" name="property_type" value="Single-family" />
                  <span>Single-family</span>
                </label>
                <label class="radio">
                  <input type="radio" name="property_type" value="Condo" />
                  <span>Condo</span>
                </label>
                <label class="radio">
                  <input type="radio" name="property_type" value="Townhouse" />
                  <span>Townhouse</span>
                </label>
                <label class="radio">
                  <input type="radio" name="property_type" value="2-4 unit" />
                  <span>2 to 4 unit</span>
                </label>
                <label class="radio">
                  <input type="radio" name="property_type" value="Other" />
                  <span>Other</span>
                </label>
              </div>
            </div>
          </div>

          <div class="row">
            <div class="field col-4">
              <label for="year_built">Year built <span class="tag">MLS</span></label>
              <input id="year_built" name="year_built" type="number" min="1600" max="2100" step="1" />
            </div>
            <div class="field col-4">
              <label for="square_footage">Square footage <span class="tag">MLS</span></label>
              <input id="square_footage" name="square_footage" type="number" min="0" step="1" />
            </div>
            <div class="field col-4">
              <label for="lot_size">Lot size <span class="tag optional">Optional · MLS</span></label>
              <input id="lot_size" name="lot_size" type="text" />
            </div>
          </div>

          <div class="row">
            <div class="field col-4">
              <label for="bedrooms">Bedrooms <span class="tag optional">Optional · MLS</span></label>
              <input id="bedrooms" name="bedrooms" type="number" min="0" step="1" />
            </div>
            <div class="field col-4">
              <label for="baths">Baths <span class="tag optional">Optional · MLS</span></label>
              <input id="baths" name="baths" type="number" min="0" step="0.5" />
            </div>
            <div class="field col-4">
              <label for="apn">APN / parcel number <span class="tag">CD / settlement</span></label>
              <input id="apn" name="apn" type="text" />
            </div>
          </div>

          <div class="row">
            <div class="field col-12 inline-check">
              <label class="checkbox">
                <input type="checkbox" id="hoa_applies" name="hoa_applies" value="Yes" />
                <span>HOA applies to this property <span class="tag">CD / MLS</span></span>
              </label>
              <div class="inline-input" data-when="hoa_applies">
                <label for="hoa_name" class="inline-label">HOA name:</label>
                <input id="hoa_name" name="hoa_name" type="text" disabled />
              </div>
            </div>
          </div>

          <div class="row">
            <div class="field col-12">
              <label for="legal_description">Legal description <span class="tag optional">Optional · PC / settlement</span></label>
              <textarea id="legal_description" name="legal_description" rows="3"></textarea>
            </div>
          </div>
        </fieldset>

        <!-- ==================== SECTION D ==================== -->
        <fieldset class="section">
          <legend>
            <span class="section-letter">D</span>
            <span class="section-title">Transaction &amp; Buyer Profile</span>
          </legend>

          <div class="row">
            <div class="field col-6">
              <label for="purchase_price">Purchase price ($) <span class="tag">CD / PC / MLS</span></label>
              <input id="purchase_price" name="purchase_price" type="number" min="0" step="1" />
            </div>
            <div class="field col-6">
              <label for="seller_concessions">Seller concessions / credits ($) <span class="tag optional">Optional · CD</span></label>
              <input id="seller_concessions" name="seller_concessions" type="number" min="0" step="1" />
            </div>
          </div>

          <div class="row">
            <div class="field col-12">
              <label class="group-label">
                Purchase type <span class="req">*</span> <span class="tag">CD</span>
              </label>
              <div class="radio-group" role="radiogroup" aria-label="Purchase type">
                <label class="radio">
                  <input type="radio" name="purchase_type" value="Financed" required />
                  <span>Financed</span>
                </label>
                <label class="radio">
                  <input type="radio" name="purchase_type" value="Cash" required />
                  <span>Cash</span>
                </label>
              </div>
            </div>
          </div>

          <div class="row">
            <div class="field col-12">
              <label class="group-label">
                Occupancy / use <span class="hint">(Primary/Secondary = owner-occupant · Investment = investor)</span> <span class="tag">R</span>
              </label>
              <div class="radio-group" role="radiogroup" aria-label="Occupancy">
                <label class="radio">
                  <input type="radio" name="occupancy" value="Primary residence" />
                  <span>Primary residence</span>
                </label>
                <label class="radio">
                  <input type="radio" name="occupancy" value="Secondary home" />
                  <span>Secondary home</span>
                </label>
                <label class="radio">
                  <input type="radio" name="occupancy" value="Investment" />
                  <span>Investment</span>
                </label>
              </div>
            </div>
          </div>

          <div class="row">
            <div class="field col-12">
              <label class="checkbox">
                <input type="checkbox" name="first_time_buyer_program" value="Yes" />
                <span>First-time-buyer program appears on the Closing Disclosure <span class="tag optional">Optional · CD</span></span>
              </label>
            </div>
          </div>
        </fieldset>

        <!-- ==================== SECTION E ==================== -->
        <fieldset class="section section-loan" id="section-e">
          <legend>
            <span class="section-letter">E</span>
            <span class="section-title">Loan &amp; Financing</span>
            <span class="section-hint">Complete only if Purchase type = Financed</span>
          </legend>

          <div class="row">
            <div class="field col-12">
              <label for="lender_name">Lender name <span class="tag">CD</span></label>
              <input id="lender_name" name="lender_name" type="text" />
            </div>
          </div>

          <div class="row">
            <div class="field col-4">
              <label for="loan_amount">Loan amount ($) <span class="tag">CD</span></label>
              <input id="loan_amount" name="loan_amount" type="number" min="0" step="1" />
            </div>
            <div class="field col-4">
              <label for="down_payment">Down payment ($) <span class="tag">CD / settlement</span></label>
              <input id="down_payment" name="down_payment" type="number" min="0" step="1" />
            </div>
            <div class="field col-4">
              <label for="ltv">LTV at closing (%) <span class="tag optional">Optional · CD</span></label>
              <input id="ltv" name="ltv" type="number" min="0" max="150" step="0.01" />
            </div>
          </div>

          <div class="row">
            <div class="field col-12">
              <label class="group-label">Loan type <span class="tag">CD</span></label>
              <div class="radio-group" role="radiogroup" aria-label="Loan type">
                <label class="radio">
                  <input type="radio" name="loan_type" value="Conventional" />
                  <span>Conventional</span>
                </label>
                <label class="radio">
                  <input type="radio" name="loan_type" value="FHA" />
                  <span>FHA</span>
                </label>
                <label class="radio">
                  <input type="radio" name="loan_type" value="VA" />
                  <span>VA</span>
                </label>
                <label class="radio">
                  <input type="radio" name="loan_type" value="USDA" />
                  <span>USDA</span>
                </label>
                <label class="radio">
                  <input type="radio" name="loan_type" value="Other" />
                  <span>Other</span>
                </label>
              </div>
            </div>
          </div>

          <div class="row">
            <div class="field col-6">
              <label for="interest_rate">Interest rate (%) <span class="tag">CD</span></label>
              <input id="interest_rate" name="interest_rate" type="number" min="0" max="30" step="0.001" />
            </div>
            <div class="field col-6">
              <label for="loan_term">Loan term (years) <span class="tag">CD</span></label>
              <input id="loan_term" name="loan_term" type="number" min="0" max="50" step="1" />
            </div>
          </div>

          <div class="row">
            <div class="field col-12">
              <label class="group-label">Rate type <span class="tag">CD</span></label>
              <div class="radio-group" role="radiogroup" aria-label="Rate type">
                <label class="radio">
                  <input type="radio" name="rate_type" value="Fixed" />
                  <span>Fixed</span>
                </label>
                <label class="radio">
                  <input type="radio" name="rate_type" value="ARM" />
                  <span>ARM</span>
                </label>
              </div>
            </div>
          </div>

          <div class="row">
            <div class="field col-12 inline-check">
              <label class="checkbox">
                <input type="checkbox" id="pmi_present" name="pmi_present" value="Yes" />
                <span>PMI / MIP present <span class="tag">CD</span></span>
              </label>
              <div class="inline-input" data-when="pmi_present">
                <label for="pmi_monthly" class="inline-label">Monthly amount ($):</label>
                <input id="pmi_monthly" name="pmi_monthly" type="number" min="0" step="0.01" disabled />
              </div>
            </div>
          </div>

          <div class="row">
            <div class="field col-12 inline-check">
              <label class="checkbox">
                <input type="checkbox" id="escrow_present" name="escrow_present" value="Yes" />
                <span>Escrow / impound account for taxes &amp; insurance <span class="tag optional">Optional · CD</span></span>
              </label>
              <div class="inline-input" data-when="escrow_present">
                <label for="escrow_monthly" class="inline-label">Monthly T&amp;I ($):</label>
                <input id="escrow_monthly" name="escrow_monthly" type="number" min="0" step="0.01" disabled />
              </div>
            </div>
          </div>

          <div class="row">
            <div class="field col-6">
