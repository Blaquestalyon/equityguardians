<script is:inline>
  (function () {
    const form = document.getElementById('intake-form-el');
    if (!form) return;
    const status = document.getElementById('form-status');
    const submitBtn = document.getElementById('submit-btn');
    const printBlank = document.getElementById('print-blank');
    const confirmation = document.getElementById('confirmation');
    const confName = document.getElementById('conf-name');
    const confMember = document.getElementById('conf-member');
    const confTime = document.getElementById('conf-time');
    const confRef = document.getElementById('conf-ref');
    const printSubmitted = document.getElementById('print-submitted');
    const submitAnother = document.getElementById('submit-another');
    const sectionE = document.getElementById('section-e');

    // Toggle a paired "when X is checked, enable field Y" behavior.
    // We disable the paired input so blank inputs don't post ghost data.
    function bindPairs() {
      document.querySelectorAll('.inline-check').forEach((wrap) => {
        const cb = wrap.querySelector('input[type="checkbox"]');
        const paired = wrap.querySelector('.inline-input');
        if (!cb || !paired) return;
        const inputs = paired.querySelectorAll('input, textarea, select');
        const sync = () => {
          const on = cb.checked;
          paired.classList.toggle('is-enabled', on);
          inputs.forEach((el) => { el.disabled = !on; if (!on) el.value = ''; });
        };
        cb.addEventListener('change', sync);
        sync();
      });
    }

    // Purchase-type = Cash disables Section E.
    function bindLoanSection() {
      const purchaseRadios = document.querySelectorAll('input[name="purchase_type"]');
      const sync = () => {
        const checked = form.querySelector('input[name="purchase_type"]:checked');
        const val = checked ? checked.value : '';
        const disable = val === 'Cash';
        if (!sectionE) return;
        sectionE.classList.toggle('is-disabled', disable);
        sectionE.querySelectorAll('input, textarea, select').forEach((el) => {
          if (el.name === 'purchase_type') return;
          // Respect the inline-input paired disable state when re-enabling.
          if (disable) {
            el.disabled = true;
            if (el.type === 'checkbox' || el.type === 'radio') el.checked = false;
            else el.value = '';
          } else {
            // Re-enable, then re-run pair sync so paired inputs stay disabled if their checkbox is off.
            el.disabled = false;
          }
        });
        if (!disable) bindPairs();
      };
      purchaseRadios.forEach((r) => r.addEventListener('change', sync));
      sync();
    }

    bindPairs();
    bindLoanSection();

    // "Print blank form": trigger the browser print dialog on the current page,
    // but hide the confirmation view first if it happens to be showing.
    if (printBlank) {
      printBlank.addEventListener('click', () => {
        document.body.classList.add('printing-form');
        window.print();
        setTimeout(() => document.body.classList.remove('printing-form'), 500);
      });
    }

    if (printSubmitted) {
      printSubmitted.addEventListener('click', () => {
        document.body.classList.add('printing-submitted');
        window.print();
        setTimeout(() => document.body.classList.remove('printing-submitted'), 500);
      });
    }

    if (submitAnother) {
      submitAnother.addEventListener('click', () => {
        confirmation.hidden = true;
        form.hidden = false;
        // Reset all fields except the pre-filled referring realtor name.
        const kept = form.referring_realtor?.value;
        form.reset();
        if (kept && form.referring_realtor) form.referring_realtor.value = kept;
        // Restore the submit button (it was left disabled after the prior success).
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Submit intake';
        }
        // Clear any lingering status message from the previous submission.
        if (status) {
          status.textContent = '';
          status.className = 'form-status';
        }
        // Re-run bindings after reset.
        bindPairs();
        bindLoanSection();
        window.scrollTo({ top: form.offsetTop - 100, behavior: 'smooth' });
      });
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!status || !submitBtn) return;

      status.textContent = '';
      status.className = 'form-status';

      // Native HTML5 required-check
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = 'Submitting…';

      try {
        const fd = new FormData(form);
        const res = await fetch('/api/partners/intake/texas', {
          method: 'POST',
          headers: { Accept: 'application/json' },
          body: fd,
        });
        const data = await res.json().catch(() => ({}));

        if (!res.ok) {
          if (res.status === 401) {
            status.innerHTML = 'Your session expired. <a href="/partners">Sign in again</a> to submit.';
          } else {
            status.textContent = data.error || 'Submission failed. Please try again.';
          }
          status.className = 'form-status form-status-error';
          submitBtn.disabled = false;
          submitBtn.textContent = 'Submit intake';
          return;
        }

        // Success: fill and reveal the confirmation panel.
        if (confName) confName.textContent = fd.get('referring_realtor') || 'Partner';
        if (confMember) confMember.textContent = String(fd.get('member_1_name') || 'the member');
        if (confTime) confTime.textContent = new Date().toLocaleString();
        if (confRef && data.recordId) confRef.textContent = data.recordId;

        confirmation.hidden = false;
        form.hidden = true;
        window.scrollTo({ top: (confirmation.offsetTop || 0) - 100, behavior: 'smooth' });
      } catch (err) {
        status.textContent = 'Network error. Please try again in a moment.';
        status.className = 'form-status form-status-error';
        submitBtn.disabled = false;
        submitBtn.textContent = 'Submit intake';
      }
    });
  })();
</script>

