---
import BaseLayout from '../../layouts/BaseLayout.astro';

// The login gate for the Partner Realtor portal. Anyone hitting a
// protected /partners/* path without a session is redirected here with
// ?next=... so we can send them back after login.
const next = Astro.url.searchParams.get('next') || '/partners/hub';
---

<BaseLayout
  title="Partner Realtors"
  description="Sign in to the Equity Guardians partner resource portal."
  noIndex={true}
>
  <section class="login-shell">
    <div class="login-bg" aria-hidden="true"></div>

    <div class="login-card reveal">
      <a href="/" class="login-brand" aria-label="Equity Guardians home">
        <img src="/logo-mark.png" alt="" width="72" height="72" class="brand-shield" />
        <div class="brand-text">
          <span class="brand-name">Equity Guardians</span>
          <span class="brand-motto">SAVE · EARN · PROTECT</span>
        </div>
      </a>

      <div class="login-heading">
        <span class="eyebrow">Partner Realtor Access</span>
        <h1>Sign in to the resource portal.</h1>
        <p class="lede">
          Enter your name and the shared partner passcode. Your name is stamped on any form you
          submit so we can attribute referrals correctly.
        </p>
      </div>

      <form id="login-form" class="login-form" method="post" action="/api/partners/login" novalidate>
        <input type="hidden" name="next" value={next} />

        <div class="field">
          <label for="name">Your name</label>
          <input
            id="name"
            name="name"
            type="text"
            autocomplete="name"
            placeholder="e.g. Jay Davis"
            required
            minlength="2"
            maxlength="80"
          />
        </div>

        <div class="field">
          <label for="passcode">Partner passcode</label>
          <input
            id="passcode"
            name="passcode"
            type="password"
            autocomplete="current-password"
            placeholder="Shared by your EG partner lead"
            required
          />
        </div>

        <button type="submit" class="submit-btn">Sign in</button>

        <div class="form-status" role="status" aria-live="polite"></div>
      </form>

      <p class="fine-print">
        Access is limited to affiliated Buyer's Realtors. Need the passcode? Contact
        <a href="mailto:admin@equityguardians.com">admin@equityguardians.com</a>.
      </p>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  (function () {
    const form = document.getElementById('login-form');
    if (!form) return;
    const status = form.querySelector('.form-status');
    const btn = form.querySelector('.submit-btn');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!status || !btn) return;

      status.textContent = '';
      status.className = 'form-status';
      btn.disabled = true;
      btn.textContent = 'Signing in…';

      try {
        const fd = new FormData(form);
        const res = await fetch('/api/partners/login', {
          method: 'POST',
          headers: { Accept: 'application/json' },
          body: fd,
        });
        const data = await res.json().catch(() => ({}));

        if (!res.ok) {
          status.textContent = data.error || 'Sign in failed. Please try again.';
          status.className = 'form-status form-status-error';
          btn.disabled = false;
          btn.textContent = 'Sign in';
          return;
        }

        const dest = (data && data.next) || '/partners/hub';
        window.location.assign(dest);
      } catch (err) {
        status.textContent = 'Network error. Please try again in a moment.';
        status.className = 'form-status form-status-error';
        btn.disabled = false;
        btn.textContent = 'Sign in';
      }
    });
  })();
</script>

<style>
  .login-shell {
    position: relative;
    min-height: calc(100vh - var(--header-h, 74px));
    padding: clamp(3rem, 8vw, 6rem) 1.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    isolation: isolate;
  }
  .login-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      radial-gradient(1200px 600px at 50% 20%, rgba(20, 184, 166, 0.08), transparent 60%),
      linear-gradient(180deg, var(--navy-900) 0%, #0A1930 100%);
  }
  .login-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to right, rgba(255,255,255,0.03) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255,255,255,0.03) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(ellipse at center, black 40%, transparent 80%);
  }

  .login-card {
    width: 100%;
    max-width: 460px;
    background: #FFFFFF;
    border-radius: 20px;
    padding: 2.5rem 2.25rem 2rem;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.35), 0 4px 16px rgba(0, 0, 0, 0.15);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .login-brand {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    text-decoration: none;
    margin-bottom: 1.75rem;
  }
  .brand-shield {
    width: 56px;
    height: 56px;
    display: block;
  }
  .brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }
  .brand-name {
    font-family: var(--font-serif);
    font-size: 1.55rem;
    color: var(--navy-900);
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .brand-motto {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.22em;
    color: var(--teal-700);
    margin-top: 0.3rem;
    font-weight: 600;
  }

  .login-heading .eyebrow {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--teal-700);
    font-weight: 600;
    margin-bottom: 0.7rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--teal-500);
    width: fit-content;
  }
  .login-heading h1 {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 2.4vw, 1.85rem);
    color: var(--navy-900);
    margin: 0.2rem 0 0.5rem;
    line-height: 1.15;
    letter-spacing: -0.01em;
  }
  .login-heading .lede {
    color: var(--slate-600);
    font-size: 0.92rem;
    line-height: 1.55;
    margin: 0;
  }

  .login-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 1.75rem;
  }
  .field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .field label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--navy-800);
    font-weight: 600;
  }
  .field input {
    font-family: inherit;
    font-size: 0.98rem;
    padding: 0.75rem 0.95rem;
    border: 1px solid var(--slate-200);
    border-radius: 10px;
    background: #FDFDFC;
    color: var(--navy-900);
    transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
  }
  .field input:focus {
    outline: none;
    border-color: var(--teal-500);
    background: #FFFFFF;
    box-shadow: 0 0 0 4px rgba(20, 184, 166, 0.15);
  }
  .field input::placeholder {
    color: #A2AAB5;
  }

  .submit-btn {
    margin-top: 0.35rem;
    background: var(--navy-900);
    color: white;
    font-family: inherit;
    font-size: 0.98rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    padding: 0.85rem 1rem;
    border-radius: 12px;
    border: 1px solid var(--navy-900);
    cursor: pointer;
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
  }
  .submit-btn:hover:not(:disabled) {
    background: var(--navy-800);
    transform: translateY(-1px);
    box-shadow: 0 8px 20px rgba(10, 25, 48, 0.25);
  }
  .submit-btn:disabled {
    opacity: 0.7;
    cursor: not-allowed;
  }

  .form-status {
    font-size: 0.88rem;
    line-height: 1.4;
    min-height: 1.2em;
    margin-top: 0.15rem;
  }
  .form-status-error {
    color: #B91C1C;
  }

  .fine-print {
    margin-top: 1.6rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--slate-200);
    font-size: 0.82rem;
    color: var(--slate-500);
    line-height: 1.5;
    text-align: center;
  }
  .fine-print a {
    color: var(--navy-800);
    text-decoration: none;
    border-bottom: 1px solid var(--teal-400);
  }
  .fine-print a:hover { color: var(--teal-700); border-color: var(--teal-700); }

  @media (max-width: 520px) {
    .login-card { padding: 2rem 1.5rem 1.5rem; border-radius: 16px; }
    .brand-shield { width: 48px; height: 48px; }
    .brand-name { font-size: 1.35rem; }
  }
</style>
