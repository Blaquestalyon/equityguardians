---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import { attorneyNetwork } from '../data/attorneys';

// Alphabetize defensively
const groups = [...attorneyNetwork].sort((a, b) => a.state.localeCompare(b.state));

const stateSlug = (s: string) => s.toLowerCase().replace(/\s+/g, '-');

const totalAttorneys = groups.reduce((n, g) => n + g.attorneys.length, 0);
const coveredStates = groups.filter((g) => g.attorneys.length > 0).length;
---

<BaseLayout
  title="Attorneys"
  description="The complete list of featured, preferred foreclosure-defense attorneys in the Equity Guardians nationwide network, organized by state."
>
  <PageHero
    eyebrow="Meet our attorneys"
    title="A nationwide network of foreclosure defense attorneys."
    description="These are not simply attorneys we know. They are vetted, qualified, tried, and proven foreclosure-defense professionals, selected for expertise, jurisdictional fit, and homeowner-first advocacy. Below is our complete featured, preferred attorneys list, organized by state. As we confirm more, we will add them."
  />

  <section>
    <div class="container">
      <div class="coverage-strip reveal">
        <div class="coverage-stat">
          <span class="stat-num">{totalAttorneys}</span>
          <span class="stat-label">Featured attorneys</span>
        </div>
        <div class="coverage-stat">
          <span class="stat-num">{coveredStates}</span>
          <span class="stat-label">States with confirmed local counsel</span>
        </div>
        <div class="coverage-stat">
          <span class="stat-num">50</span>
          <span class="stat-label">States covered by the network</span>
        </div>
      </div>

      <nav class="state-jump reveal" aria-label="Jump to a state">
        {groups.map((g) => (
          <a href={`#${stateSlug(g.state)}`} class={`jump-chip${g.attorneys.length === 0 ? ' jump-chip-pending' : ''}`}>
            {g.state}
          </a>
        ))}
      </nav>

      <div class="states">
        {groups.map((g) => (
          <section class="state-block reveal" id={stateSlug(g.state)}>
            <header class="state-head">
              <h2>{g.state}</h2>
              {g.attorneys.length > 0 && (
                <span class="state-count">
                  {g.attorneys.length} {g.attorneys.length === 1 ? 'attorney' : 'attorneys'}
                </span>
              )}
            </header>

            {g.attorneys.length === 0 && g.note && (
              <p class="state-note">{g.note}</p>
            )}

            {g.attorneys.length > 0 && (
              <div class="attorney-list">
                {g.attorneys.map((a) => (
                  <article class="attorney-row">
                    <div class="attorney-body">
                      <h3 class="attorney-name">{a.name}</h3>
                      <p class="attorney-firm">
                        {a.website ? (
                          <a href={a.website} target="_blank" rel="noopener noreferrer" class="firm-link">
                            {a.firm}
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="12" height="12" aria-hidden="true"><path d="M7 17L17 7M9 7h8v8"/></svg>
                          </a>
                        ) : (
                          <span>{a.firm}</span>
                        )}
                      </p>
                      {a.bio && <p class="attorney-bio">{a.bio}</p>}
                    </div>
                  </article>
                ))}
              </div>
            )}
          </section>
        ))}
      </div>

      <div class="network-note reveal">
        <div>
          <span class="eyebrow">Nationwide coverage</span>
          <h3>Coverage across all 50 states.</h3>
          <p>
            Homeowners become members when they close on their home with an affiliated Buyer&rsquo;s Realtor,
            and their protection stays active for the life of the deed of trust. If the threat of imminent
            foreclosure ever surfaces, their case manager, a vetted attorney licensed in their state, and
            their realtor are ready to move in their respective capacities to protect the home and the equity in it.
          </p>
        </div>
        <a href="/contact" class="btn btn-primary">Learn about membership</a>
      </div>

      <aside class="network-disclaimer reveal">
        <strong>A note on our featured firms.</strong> The preferred attorneys and law firms listed above are selected based on confidence in performance, as determined by Equity Guardians&rsquo; ongoing due diligence. Featured selections may change over time as our review process continues and the network evolves.
      </aside>
    </div>
  </section>

  <section class="section-alt">
    <div class="container">
      <div class="section-heading reveal">
        <span class="eyebrow">Selection methodology</span>
        <h2>A three-layer process behind every preferred attorney.</h2>
        <p class="section-dek">
          We do not simply pick names off a list. Every preferred attorney in the network clears a stack
          of three independent evaluations, beginning with one of the most rigorous peer-review
          methodologies in the legal profession.
        </p>
      </div>
      <div class="grid grid-3 mt-4">
        <div class="layer reveal">
          <div class="layer-num">Layer 01</div>
          <h4>Super Lawyers peer-review methodology</h4>
          <p>
            We start with the multi-phase peer nomination and research process powered by
            <a href="https://www.superlawyers.com/about/selection-process/" target="_blank" rel="noopener noreferrer">Super Lawyers</a>,
            which is protected under
            <a href="https://patents.justia.com/assignee/thomson-reuters-grc-inc" target="_blank" rel="noopener noreferrer">U.S. Pat. No. 8,412,564</a>
            (Thomson Reuters, granted April 2, 2013): a patented system and method for identifying excellence within a profession.
          </p>
        </div>
        <div class="layer reveal">
          <div class="layer-num">Layer 02</div>
          <h4>Equity Guardians individual research</h4>
          <p>
            On top of that baseline, our team performs firm-by-firm research: foreclosure-defense caseload,
            outcomes in the relevant jurisdiction, disciplinary history, and references confirming a
            homeowner-first posture rather than a servicing-industry one.
          </p>
        </div>
        <div class="layer reveal">
          <div class="layer-num">Layer 03</div>
          <h4>VERIDEX decision analytics</h4>
          <p>
            Finally, VERIDEX decision analytics scores and cross-checks the picture, so every preferred
            attorney reflects a converging judgment from peer review, our own research, and quantitative signal,
            not any single opinion.
          </p>
        </div>
      </div>

      <div class="section-heading reveal mt-6">
        <span class="eyebrow">Vetting standards</span>
        <h2>The bar every firm must clear.</h2>
      </div>
      <div class="grid grid-3 mt-4">
        <div class="std reveal">
          <div class="std-num">01</div>
          <h4>Verified experience</h4>
          <p>Minimum threshold of foreclosure-defense caseload and outcomes in the relevant jurisdiction.</p>
        </div>
        <div class="std reveal">
          <div class="std-num">02</div>
          <h4>Clean disciplinary record</h4>
          <p>Ongoing monitoring of state bar standing and disciplinary history.</p>
        </div>
        <div class="std reveal">
          <div class="std-num">03</div>
          <h4>Homeowner-first advocacy</h4>
          <p>References and case reviews confirm firms represent homeowners, not the servicing industry.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Coverage strip */
  .coverage-strip {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    padding: 1.75rem 2rem;
    background: var(--navy-950);
    color: white;
    border-radius: var(--radius-lg);
    margin-bottom: 2.5rem;
  }
  @media (max-width: 700px) { .coverage-strip { grid-template-columns: 1fr; padding: 1.25rem 1.5rem; } }
  .coverage-stat { display: flex; flex-direction: column; gap: 0.35rem; }
  .stat-num {
    font-family: var(--font-serif);
    font-size: 2.1rem;
    line-height: 1;
    color: var(--teal-400);
    font-weight: 500;
  }
  .stat-label { color: rgba(255,255,255,0.72); font-size: 0.88rem; }

  /* Jump nav */
  .state-jump {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    padding: 1.25rem;
    background: var(--sand-50, #FBF7EE);
    border: 1px solid #E9DEC1;
    border-radius: var(--radius-lg);
    margin-bottom: 3rem;
  }
  .jump-chip {
    display: inline-flex;
    align-items: center;
    padding: 0.35rem 0.7rem;
    background: white;
    border: 1px solid var(--slate-200);
    border-radius: 999px;
    font-size: 0.82rem;
    color: var(--navy-800);
    text-decoration: none;
    transition: background 0.2s, border-color 0.2s, color 0.2s;
  }
  .jump-chip:hover { background: var(--navy-800); border-color: var(--navy-800); color: white; }
  .jump-chip-pending { color: var(--slate-500); border-style: dashed; }
  .jump-chip-pending:hover { background: var(--slate-500); border-color: var(--slate-500); color: white; }

  /* State blocks */
  .states { display: flex; flex-direction: column; gap: 2.5rem; }
  .state-block { scroll-margin-top: 100px; }
  .state-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: 0.85rem;
    border-bottom: 2px solid var(--teal-500);
    margin-bottom: 1.25rem;
    flex-wrap: wrap;
  }
  .state-head h2 {
    font-family: var(--font-serif);
    font-size: 1.65rem;
    margin: 0;
    color: var(--navy-900);
  }
  .state-count {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--teal-700);
    font-weight: 600;
  }
  .state-note {
    padding: 1rem 1.25rem;
    background: #FBF7EE;
    border: 1px solid #E9DEC1;
    border-radius: var(--radius-lg);
    color: var(--slate-700);
    font-size: 0.92rem;
    line-height: 1.55;
    margin: 0;
  }

  /* Attorney rows */
  .attorney-list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }
  @media (max-width: 800px) { .attorney-list { grid-template-columns: 1fr; } }

  .attorney-row {
    background: white;
    border: 1px solid var(--slate-200);
    border-radius: var(--radius-lg);
    padding: 1.35rem 1.5rem;
    transition: transform 0.25s, box-shadow 0.25s, border-color 0.25s;
  }
  .attorney-row:hover { transform: translateY(-2px); box-shadow: var(--shadow-lg); border-color: var(--teal-400); }
  .attorney-name {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    color: var(--navy-900);
    margin: 0 0 0.25rem;
    line-height: 1.3;
  }
  .attorney-firm {
    font-size: 0.9rem;
    color: var(--navy-800);
    font-weight: 500;
    margin: 0;
    line-height: 1.4;
  }
  .firm-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    color: var(--navy-800);
    text-decoration: none;
    border-bottom: 1px solid var(--teal-400);
    padding-bottom: 1px;
    transition: color 0.2s, border-color 0.2s;
  }
  .firm-link:hover { color: var(--teal-700); border-color: var(--teal-700); }
  .firm-link svg { opacity: 0.7; transition: opacity 0.2s, transform 0.2s; }
  .firm-link:hover svg { opacity: 1; transform: translate(1px, -1px); }
  .attorney-bio {
    color: var(--slate-600);
    font-size: 0.92rem;
    line-height: 1.55;
    margin-top: 0.7rem;
    margin-bottom: 0;
  }

  /* Nationwide-coverage callout */
  .network-note {
    margin-top: 3rem;
    padding: 2.25rem;
    background: var(--navy-950);
    color: white;
    border-radius: var(--radius-lg);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .network-note h3 { color: white; font-size: 1.5rem; margin: 0.6rem 0 0.5rem; }
  .network-note p { color: rgba(255,255,255,0.72); max-width: 60ch; font-size: 0.94rem; }
  .network-note .eyebrow { color: var(--teal-400); }
  .network-note .eyebrow::before { background: var(--teal-400); }

  .network-disclaimer {
    margin-top: 2rem;
    padding: 1.25rem 1.5rem;
    background: #FBF7EE;
    border: 1px solid #E9DEC1;
    border-radius: var(--radius-lg);
    color: var(--slate-700);
    font-size: 0.92rem;
    line-height: 1.55;
  }
  .network-disclaimer strong { color: var(--navy-800); font-weight: 600; }

  /* Methodology + standards blocks (unchanged) */
  .section-dek { color: var(--slate-600); font-size: 1rem; max-width: 62ch; margin-top: 0.75rem; }
  .mt-6 { margin-top: 4rem; }

  .layer { padding: 1.5rem 0; border-top: 2px solid var(--teal-700); }
  .layer-num { font-family: var(--font-mono); font-size: 0.78rem; letter-spacing: 0.2em; color: var(--teal-700); font-weight: 600; text-transform: uppercase; }
  .layer h4 { font-size: 1.15rem; margin: 0.65rem 0 0.5rem; }
  .layer p { color: var(--slate-600); font-size: 0.92rem; }
  .layer a { color: var(--navy-800); text-decoration: none; border-bottom: 1px solid var(--teal-400); padding-bottom: 1px; transition: color 0.2s, border-color 0.2s; }
  .layer a:hover { color: var(--teal-700); border-color: var(--teal-700); }

  .std { padding: 1.5rem 0; border-top: 2px solid var(--navy-900); }
  .std-num { font-family: var(--font-mono); font-size: 0.78rem; letter-spacing: 0.2em; color: var(--teal-700); font-weight: 600; }
  .std h4 { font-size: 1.15rem; margin: 0.65rem 0 0.5rem; }
  .std p { color: var(--slate-600); font-size: 0.92rem; }
</style>
